# E2E-only env. These are FAKE, non-secret values used by `vite --mode e2e`.
# They exist solely so isSupabaseConfigured is true (form enabled). Playwright
# intercepts every Supabase/Nominatim request, so no call ever leaves the browser
# — and the dead host below means even a missed request can never reach production.
VITE_SUPABASE_URL=https://e2e-fake.supabase.invalid
VITE_SUPABASE_ANON_KEY=e2e-fake-anon-key
